# ============================================================
# Gemini Clone — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# === GOOGLE GEMINI ===
GEMINI_API_KEY=your_google_gemini_api_key_here

# === SERVER ===
PORT=5000
NODE_ENV=development   # development | production

# === DATABASE ===
# Get your free connection string from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/gemini-clone?retryWrites=true&w=majority

# === CORS SECURITY ===
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://gemini-clone-mu-lyart.vercel.app

# === FIREBASE ADMIN SDK ===
# Paste your Service Account JSON (minified) as a single-line string
# Get it from: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# === FIREBASE CLIENT SDK (Vite Prefix Required) ===
VITE_API_BASE_URL=http://localhost:5000
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# === DEV TOOLS ===
# Set to true to mock streaming responses without calling Gemini API
MOCK_STREAM=false

# === OBSERVABILITY ===
SENTRY_DSN=your_sentry_dsn_here
VITE_SENTRY_DSN=your_sentry_dsn_here
